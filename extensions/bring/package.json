{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "bring",
  "title": "Bring!",
  "description": "Manage your Bring! shopping list via Raycast.",
  "icon": "bring_logo.png",
  "author": "ilian",
  "categories": [
    "Productivity",
    "Web",
    "Applications"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "search-items",
      "title": "Manage List",
      "description": "Manging your shopping list.",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "personalAccessToken",
      "title": "Access Token",
      "placeholder": "Look it up on https://web.getbring.com/",
      "description": "See the extension's README for instructions to obtain the personal access token",
      "type": "textfield",
      "required": true
    },
    {
      "name": "userUUID",
      "title": "User UUID",
      "description": "See the extension's README for instructions to obtain the userUUID",
      "type": "textfield",
      "required": true
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.57.0",
    "axios": "^1.4.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "1.0.5",
    "@types/node": "18.8.3",
    "@types/react": "18.0.9",
    "eslint": "^7.32.0",
    "prettier": "^2.5.1",
    "typescript": "^4.4.3"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
